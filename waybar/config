{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,
    "modules-left": [
        "sway/workspaces",
        "network"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "custom/gpu",
        "backlight",
        "pulseaudio",
        "battery",
        "tray",
    	"sway/language"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

    "tray": {
        "spacing": 10
    },

    "clock": {
        "format": "{:%H:%M  |  %A, %b %d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },


    "cpu": {
        "format": "CPU {usage}%",
        "tooltip": false
    },

    "memory": {
        "format": "RAM {}%"
    },


    "sway/language": {
    "format": "{short}"
    },

    "custom/gpu": {
        "exec": "nvidia-smi --query-gpu=memory.used --format=csv,noheader,nounits",
        "format": "GPU {} MiB",
        "interval": 5,
        "tooltip": false
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["", ""]
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },

    "network": {
    // "interface": "wlp*", // Filter for a specific interface if needed
    "format-wifi": "  {bandwidthDownBytes}",
    "format-ethernet": "  {bandwidthDownBytes}",
    "format-disconnected": "⚠ Disconnected",
    "tooltip-format": "{ifname} via {gwaddr} ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
    "tooltip-format-ethernet": "{ifname} ",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 2, // Update every 2 seconds for accuracy
    "max-length": 50
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    }
}
